---
import Base from "@/layouts/Base.astro";
import Swatch from "@/components/Swatch/Swatch.astro";
---

<style>
  .swatches__wrapper {
    display: flex;
  }

  .swatches__container {
    display: flex;
  }

  .swatch__card {
    display: flex;
    flex-direction: column;
  }

  .swatch__color {
    aspect-ratio: 1/1;
    width: 250px;
    color: white;
  }
</style>

<Base>
  <h1>PVD Meshworks</h1>
  <h2>PVD Meshworks</h2>
  <h3>PVD Meshworks</h3>
  <h4>PVD Meshworks</h4>
  <h5>PVD Meshworks</h5>
  <p>PVD Meshworks</p>

  <div class=".swatches__wrapper">
    <h3 class=".swatches__title">Background</h3>
    <div class=".swatches__container">
      <Swatch title="testing" color="var(--pink-7)" />
    </div>
  </div>
</Base>
