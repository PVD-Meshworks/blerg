<style is:global>
  .full-bleed-wrapper {
    display: grid;
    grid-template-columns:
      1fr
      min(80ch, 100%)
      1fr;
    gap: var(--size-2);
  }

  .full-bleed-wrapper > * {
    grid-column: 2;
  }

  .full-bleed {
    width: 100%;
    grid-column: 1 / 4;
  }
</style>
<main class="full-bleed-wrapper">
  <slot />
</main>
